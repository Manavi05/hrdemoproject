{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.hr.portal",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZPROJECT_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/metadata.xml"
        }
      },
      "leaveDataSource": {
        "uri": "/sap/opu/odata4/sap/zhr_serv_bind_lr/srvd/sap/zhr_serv_def_lr/0001/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/metadata_leave.xml"
        }
      }
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.hr.portal.view.App",
      "type": "XML",
      "id": "rootApp",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.tnt": {},
        "sap.f": {},
        "sap.viz": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.hr.portal.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "settings": {
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Inline",
          "refreshAfterChange": true
        }
      },
      "leaveModel": {
        "dataSource": "leaveDataSource",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.hr.portal.view",
        "controlId": "appId",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        { "name": "RouteLogin", "pattern": "", "target": "TargetLogin" },
        { "name": "RouteDashboard", "pattern": "dashboard", "target": "TargetDashboard" },
        { "name": "RouteEmployees", "pattern": "employees", "target": "TargetEmployees" },
        { "name": "RouteAttendance", "pattern": "attendance", "target": "TargetAttendance" },
        { "name": "RouteLeaves", "pattern": "leave", "target": "TargetLeaves" },
        { "name": "RouteDocuments", "pattern": "documents", "target": "TargetDocuments" },
        { "name": "RouteEmployeeDashboard", "pattern": "employee-portal", "target": "TargetEmployeeDashboard" },
        { "name": "RouteProfile", "pattern": "employee/profile", "target": "TargetProfile" },
        { "name": "RouteTasks", "pattern": "tasks", "target": "TargetTasks" },
        { "name": "RouteEmpAttendance", "pattern": "empattendance", "target": "TargetEmpAttendance" },
        { "name": "RouteEmpDocuments", "pattern": "empdocuments", "target": "TargetEmpDocuments" }
      ],
      "targets": {
        "TargetLogin": { "viewName": "Login", "viewLevel": 0 },
        "TargetDashboard": { "viewName": "Dashboard", "viewLevel": 1 },
        "TargetEmployees": { "viewName": "Employees", "viewLevel": 2 },
        "TargetAttendance": { "viewName": "Attendance", "viewLevel": 3 },
        "TargetLeaves": { "viewName": "Leave", "viewLevel": 4 },
        "TargetDocuments": { "viewName": "Documents", "viewLevel": 5 },
        "TargetEmployeeDashboard": { "viewName": "EmployeeDashboard", "viewLevel": 1 },
        "TargetProfile": { "viewName": "Profile", "viewLevel": 2 },
        "TargetTasks": { "viewName": "EmpTasks", "viewLevel": 4 },
        "TargetEmpAttendance": { "viewName": "EmpAttendance", "viewLevel": 3 },
        "TargetEmpDocuments": { "viewName": "EmpDocuments", "viewLevel": 5 }
      }
    }
  }
}