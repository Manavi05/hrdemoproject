{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.hr.portal",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.hr.portal.view.App",
      "type": "XML",
      "id": "rootApp",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.tnt": {},
        "sap.viz": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.hr.portal.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.hr.portal.view",
        "controlId": "appId",
        "controlAggregation": "pages",
        "transition": "slide",
        "async": true
      },
      "routes": [
        {
          "name": "RouteDashboard",
          "pattern": "",
          "target": "TargetDashboard"
        },
        {
          "name": "RouteEmployees",
          "pattern": "employees",
          "target": "TargetEmployees"
        },
        {
          "name": "RouteAttendance",
          "pattern": "attendance",
          "target": "TargetAttendance"
        },
        {
          "name": "RouteLeaves",
          "pattern": "leave",
          "target": "TargetLeaves"
        },
        {
          "name": "RouteDocuments",
          "pattern": "documents",
          "target": "TargetDocuments"
        }
      ],
      "targets": {
        "TargetDashboard": {
          "viewName": "Dashboard",
          "viewLevel": 1
        },
        "TargetEmployees": {
          "viewName": "Employees",
          "viewLevel": 2
        },
        "TargetAttendance": {
          "viewName": "Attendance",
          "viewLevel": 3
        },
        "TargetLeaves": {
          "viewName": "Leave",
          "viewLevel": 4
        },
        "TargetDocuments": {
          "viewName": "Documents",
          "viewLevel": 5
        }
      }
    }
  }
}