<mvc:View
    controllerName="com.hr.portal.controller.Documents"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="Document Management" backgroundDesign="Transparent" showHeader="false">
        <content>
            <VBox class="sapUiMediumMargin">
                
                <Title text="Employee Documents" level="H1" titleStyle="H3" />
                <Text text="Review and download employee records and certifications" class="sapUiSmallMarginBottom" />

                <!-- Tiles with Dynamic Numbers -->
                <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginBottom">
                    <VBox class="kpiCard" width="31%">
                        <Text text="{stats>/total}" class="kpiNumber" />
                        <Text text="Total Documents" class="kpiLabel" />
                    </VBox>
                    <VBox class="kpiCard" width="31%">
                        <Text text="{stats>/pending}" class="kpiNumber" />
                        <Text text="Pending Review" class="kpiLabel" />
                    </VBox>
                    <VBox class="kpiCard" width="31%">
                        <Text text="{stats>/approved}" class="kpiNumber" />
                        <Text text="Approved Documents" class="kpiLabel" />
                    </VBox>
                </HBox>

                <!-- Simplified Search Bar (Filter removed) -->
                <VBox class="whiteSectionCard sapUiContentPadding sapUiSmallMarginBottom">
                    <SearchField 
                        placeholder="Search by employee name..." 
                        width="400px" 
                        liveChange=".onSearch" />
                </VBox>

                <VBox class="whiteSectionCard">
                    <!-- Ensure items matches your SEGW Entity Set exactly -->
                    <Table id="docsTable" items="{/DocumentsSet}">
                        <columns>
                            <Column width="100px"><Text text="Emp ID" /></Column>
                            <Column width="200px"><Text text="Employee" /></Column>
                            <Column><Text text="Document Name" /></Column>
                            <Column><Text text="Category" /></Column>
                            <Column><Text text="Upload Date" /></Column>
                            <Column><Text text="Status" /></Column>
                            <Column hAlign="End"><Text text="Actions" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle">
                                <cells>
                                    <Text text="{EMP_ID}" />
                                    <HBox alignItems="Center">
                                        <Avatar src="{Photo}" displaySize="XS" class="sapUiTinyMarginEnd" />
                                        <Text text="{EMP_NAME}" />
                                    </HBox>
                                    <Link text="{DOC_NAME}" href="{LINK}" target="_blank" />
                                    <Text text="{CATEGORY}" />
                                    <Text text="{UPLOAD_DATE}" />
                                    <ObjectStatus text="{STATUS}" 
                                        state="{= ${STATUS} === 'Approved' ? 'Success' : 'Warning' }" 
                                        inverted="true" />
                                    <HBox justifyContent="End">
                                        <Button icon="sap-icon://download" type="Transparent" press="onDownloadDoc" />
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>