<mvc:View controllerName="com.hr.portal.controller.Employees"
    xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.f" xmlns:core="sap.ui.core">
    <Page showHeader="false" backgroundDesign="Standard">
        <content>
            <VBox class="sapUiSmallMargin">
                <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                    <VBox>
                        <Title text="Employee Directory" level="H1" titleStyle="H3" />
                        <Text text="Manage your organization's workforce" color="Secondary" />
                    </VBox>
                    <HBox>
                        <Button text="Add Employee" icon="sap-icon://add" type="Emphasized" press="onAddEmployeePress" />
                    </HBox>
                </HBox>

                <HBox class="sapUiSmallMarginBottom" alignItems="Center">
                    <SearchField placeholder="Search by name, ID, or email..." width="400px" class="sapUiSmallMarginEnd" />
                    <Select width="250px" selectedKey="All">
                        <core:Item key="All" text="All Departments" />
                    </Select>
                </HBox>

                <Table id="employeeTable" items="{/EmployeesSet}" class="sapUiResponsiveMargin customTable">
                    <columns>
                        <Column width="10%"><Text text="ID" /></Column>
                        <Column width="15%"><Text text="Employee" /></Column>
                        <Column width="20%"><Text text="Email" /></Column>
                        <Column width="15%"><Text text="Role" /></Column>
                        <Column width="15%"><Text text="Department" /></Column>
                        <Column width="15%"><Text text="Status" /></Column>
                        <Column hAlign="End" width="10%"><Text text="Actions" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem vAlign="Middle">
                            <cells>
                                <Text text="{EMP_ID}" font="Bold" />
                                <Text text="{EMP_NAME}" font="Bold" />
                                <Text text="{EMAIL}" />
                                <Text text="{ROLE}" />
                                <Text text="{DEPARTMENT}" />
                                <ObjectStatus 
                                    text="{STATUS}" 
                                    state="{= ${STATUS} === 'Active' ? 'Success' : (${STATUS} === 'On Leave' ? 'Warning' : 'Error') }"
                                    inverted="true" />
                                <Button icon="sap-icon://edit" type="Transparent" press="onEditEmployeePress" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>