<mvc:View
    controllerName="com.hr.portal.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls">
    <Page title="HR Overview" backgroundDesign="Transparent" showHeader="false">
        <content>
            <VBox width="100%" class="dashboardWrapper">
                <VBox class="sapUiMediumMargin">
                    <Title text="Welcome back! Here's your HR overview." class="sapUiSmallMarginBottom" />

                    <HBox width="100%" justifyContent="SpaceBetween" class="kpiContainer sapUiSmallMarginBottom">
                        <GenericTile header="Pending Leaves" subheader="+3 from yesterday" class="kpiTile kpiActive">
                            <TileContent footer="12"><ImageContent src="sap-icon://calendar" color="Critical"/></TileContent>
                        </GenericTile>
                        <GenericTile header="Total Headcount" subheader="+5 this month" class="kpiTile">
                            <TileContent footer="247"><ImageContent src="sap-icon://group" /></TileContent>
                        </GenericTile>
                        <GenericTile header="Attendance Alerts" subheader="-2 from yesterday" class="kpiTile">
                            <TileContent footer="5"><ImageContent src="sap-icon://alert" color="Negative"/></TileContent>
                        </GenericTile>
                        <GenericTile header="Completed Reviews" subheader="+12% this quarter" class="kpiTile">
                            <TileContent footer="89%"><ImageContent src="sap-icon://sys-enter-2" color="Positive"/></TileContent>
                        </GenericTile>
                    </HBox>

                    <layout:Grid defaultSpan="L12 M12 S12" hSpacing="1" vSpacing="0">
                        <VBox>
                            <layoutData><layout:GridData span="L8 M12 S12" /></layoutData>
                            
                            <VBox class="customCard sapUiSmallMarginBottom">
                                <Title text="Recent Activity" class="sapUiSmallMargin" />
                                <List items="{/Activities}" separators="None">
                                    <CustomListItem>
                                        <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMargin">
                                            <HBox alignItems="Center">
                                                <Avatar src="{Icon}" displaySize="S" class="sapUiSmallMarginEnd" />
                                                <VBox>
                                                    <Text text="{User} {Action}" class="boldText" />
                                                    <Text text="{Time}" class="subText" />
                                                </VBox>
                                            </HBox>
                                            <ObjectStatus text="{Status}" state="{State}" inverted="true" class="statusBadge" />
                                        </HBox>
                                    </CustomListItem>
                                </List>
                            </VBox>

                            <HBox justifyContent="SpaceBetween" width="100%">
                                <VBox width="49%" class="customCard">
                                    <Title text="Employee Distribution" class="sapUiSmallMargin" />
                                    <viz:VizFrame id="idPieChart" vizType="pie" width="100%" height="350px" />
                                </VBox>
                                <VBox width="49%" class="customCard">
                                    <Title text="Monthly Leave Trend" class="sapUiSmallMargin" />
                                    <viz:VizFrame id="idLineChart" vizType="line" width="100%" height="350px" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox class="customCard">
                            <layoutData><layout:GridData span="L4 M12 S12" /></layoutData>
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                <Title text="Pending Approvals" />
                                <ObjectStatus text="4 pending" state="Warning" inverted="true" />
                            </HBox>
                            <List items="{/Approvals}" separators="None">
                                <CustomListItem>
                                    <VBox class="approvalSubCard">
                                        <HBox class="sapUiSmallMarginBottom" alignItems="Center">
                                            <Avatar src="{Icon}" displaySize="S" class="sapUiSmallMarginEnd" />
                                            <VBox>
                                                <Text text="{User}" class="boldText" />
                                                <Text text="{Type} • {Days}" class="subText" />
                                            </VBox>
                                        </HBox>
                                        <HBox width="100%" justifyContent="SpaceBetween" class="approvalBtnRow">
                                            <Button text="Approve" type="Accept" class="btnFull" />
                                            <Button text="Reject" type="Reject" class="btnFull btnRejectOutline" />
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </List>
                        </VBox>
                    </layout:Grid>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>