<mvc:View
    controllerName="com.hr.portal.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
    <Page id="_IDGenPage" title="Welcome back! Here's your HR overview." backgroundDesign="Transparent">
        <content>
            <VBox id="_IDGenVBox1" class="sapUiSmallMargin">
                <HBox id="_IDGenHBox" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                    <GenericTile id="_IDGenGenericTile" header="Pending Leaves" subheader="+3 from yesterday" class="kpiTile">
                        <TileContent id="_IDGenTileContent" footer="12"><ImageContent id="_IDGenImageContent" src="sap-icon://calendar" /></TileContent>
                    </GenericTile>
                    <GenericTile id="_IDGenGenericTile1" header="Total Headcount" subheader="+5 this month" class="kpiTile">
                        <TileContent id="_IDGenTileContent1" footer="247"><ImageContent id="_IDGenImageContent1" src="sap-icon://group" /></TileContent>
                    </GenericTile>
                    <GenericTile id="_IDGenGenericTile2" header="Attendance Alerts" subheader="-2 from yesterday" class="kpiTile">
                        <TileContent id="_IDGenTileContent2" footer="5"><ImageContent id="_IDGenImageContent2" src="sap-icon://alert" /></TileContent>
                    </GenericTile>
                    <GenericTile id="_IDGenGenericTile3" header="Completed Reviews" subheader="+12% this quarter" class="kpiTile">
                        <TileContent id="_IDGenTileContent3" footer="89%"><ImageContent id="_IDGenImageContent3" src="sap-icon://sys-enter-2" /></TileContent>
                    </GenericTile>
                </HBox>

                <layout:Grid id="_IDGenGrid" defaultSpan="L6 M6 S12" hSpacing="1" vSpacing="1">
                    <VBox id="_IDGenVBox2" class="chartCard">
                        <Title id="_IDGenTitle1" text="Employee Distribution" class="sapUiSmallMargin" />
                        <viz:VizFrame id="idPieChart" vizType="pie" width="100%">
                            <viz:dataset>
                                <viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{/DeptData}">
                                    <viz.data:dimensions><viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="Dept" value="{Dept}" /></viz.data:dimensions>
                                    <viz.data:measures><viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="Count" value="{Count}" /></viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem id="_IDGenFeedItem" uid="size" type="Measure" values="Count" />
                                <viz.feeds:FeedItem id="_IDGenFeedItem1" uid="color" type="Dimension" values="Dept" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>

                    <VBox id="_IDGenVBox3" class="chartCard">
                        <Title id="_IDGenTitle2" text="Monthly Leave Trend" class="sapUiSmallMargin" />
                        <viz:VizFrame id="idLineChart" vizType="line" width="100%">
                            <viz:dataset>
                                <viz.data:FlattenedDataset id="_IDGenFlattenedDataset1" data="{/LeaveTrend}">
                                    <viz.data:dimensions><viz.data:DimensionDefinition id="_IDGenDimensionDefinition1" name="Month" value="{Month}" /></viz.data:dimensions>
                                    <viz.data:measures><viz.data:MeasureDefinition id="_IDGenMeasureDefinition1" name="Total" value="{Total}" /></viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem id="_IDGenFeedItem2" uid="valueAxis" type="Measure" values="Total" />
                                <viz.feeds:FeedItem id="_IDGenFeedItem3" uid="categoryAxis" type="Dimension" values="Month" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                </layout:Grid>
            </VBox>
        </content>
    </Page>
</mvc:View>