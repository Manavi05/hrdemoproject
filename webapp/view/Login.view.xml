<mvc:View
    controllerName="com.hr.portal.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    displayBlock="true">
    <Shell id="loginShell">
        <App id="loginApp">
            <Page showHeader="false" backgroundDesign="List">
                <content>
                    <VBox justifyContent="Center" alignItems="Center" class="loginContainer">
                        <Avatar src="sap-icon://customer-and-contacts" displaySize="L" class="sapUiMediumMarginBottom loginIcon" />
                        
                        <Title text="Welcome to HR Portal" level="H1" titleStyle="H2" class="sapUiSmallMarginBottom" />
                        <Text text="Please select your role and login" class="sapUiMediumMarginBottom subText" />

                        <VBox width="100%" maxWidth="400px" class="loginCard">
                            <Label text="I am an:" class="sapUiSmallMarginBottom boldText" />
                            <SegmentedButton id="roleSelector" selectedKey="HR" width="100%" class="sapUiMediumMarginBottom">
                                <items>
                                    <SegmentedButtonItem text="HR Manager" key="HR" icon="sap-icon://manager" />
                                    <SegmentedButtonItem text="Employee" key="EMP" icon="sap-icon://employee" />
                                </items>
                            </SegmentedButton>

                            <VBox class="sapUiSmallMarginBottom">
                                <Label text="Username" />
                                <Input id="usernameInput" placeholder="Enter username..." />
                            </VBox>

                            <VBox class="sapUiMediumMarginBottom">
                                <Label text="Password" />
                                <Input id="passwordInput" type="Password" placeholder="Enter password..." />
                            </VBox>

                            <Button text="Login to Dashboard" type="Emphasized" width="100%" press=".onLogin" class="loginBtn" />
                            
                            <HBox justifyContent="Center" class="sapUiSmallMarginTop">
                                <Link text="Forgot Password?" press=".onForgotPassword" />
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </Page>
        </App>
    </Shell>
</mvc:View>