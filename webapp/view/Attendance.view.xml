<mvc:View
    controllerName="com.hr.portal.controller.Attendance"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page showHeader="false" backgroundDesign="Transparent">
        <content>
            <VBox class="sapUiMediumMargin">
                <!-- Header Section -->
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                    <VBox>
                        <Title text="Attendance Monitoring" level="H1" titleStyle="H3" />
                        <Text text="Track daily attendance and work hours" class="subText" />
                    </VBox>
                    <Button text="Generate Report" icon="sap-icon://manager-insight" type="Ghost" press="onGenerateReport" />
                </HBox>

                <!-- KPI Tiles -->
                <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginBottom">
                    <VBox class="kpiCard" width="23%">
                        <Title text="{/Stats/Total}" titleStyle="H4" />
                        <Text text="Total Employees" />
                    </VBox>
                    <VBox class="kpiCard" width="23%">
                        <HBox justifyContent="SpaceBetween">
                            <Title text="{/Stats/OnTime}" titleStyle="H4" />
                            <core:Icon src="sap-icon://accept" color="Positive" />
                        </HBox>
                        <Text text="On Time Today" />
                    </VBox>
                    <VBox class="kpiCard" width="23%">
                        <HBox justifyContent="SpaceBetween">
                            <Title text="{/Stats/Late}" titleStyle="H4" />
                            <core:Icon src="sap-icon://alert" color="Critical" />
                        </HBox>
                        <Text text="Late Arrivals" />
                    </VBox>
                    <VBox class="kpiCard" width="23%">
                        <HBox justifyContent="SpaceBetween">
                            <Title text="{/Stats/Absent}" titleStyle="H4" />
                            <core:Icon src="sap-icon://decline" color="Negative" />
                        </HBox>
                        <Text text="Absent" />
                    </VBox>
                </HBox>

                <!-- Search Bar Only -->
                <VBox class="whiteSectionCard sapUiContentPadding sapUiSmallMarginBottom">
                    <SearchField placeholder="Search employees..." width="400px" liveChange="onSearch" />
                </VBox>

                <!-- Attendance Table -->
                <VBox class="whiteSectionCard">
                    <Table id="attendanceTable" items="{/Attendance}">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="Today's Attendance" level="H2" />
                                <ToolbarSpacer />
                                <Text text="Monday, April 27, 2026" />
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column><Text text="ID" /></Column>
                            <Column><Text text="Employee" /></Column>
                            <Column><Text text="Department" /></Column>
                            <Column><Text text="Check In" /></Column>
                            <Column><Text text="Check Out" /></Column>
                            <Column><Text text="Work Hours" /></Column>
                            <Column><Text text="Status" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle">
                                <cells>
                                    <Text text="{ID}" />
                                    <HBox alignItems="Center">
                                        <Avatar displaySize="XS" class="sapUiTinyMarginEnd" />
                                        <Text text="{Name}" />
                                    </HBox>
                                    <Text text="{Dept}" />
                                    <Text text="{CheckIn}" />
                                    <Text text="{CheckOut}" />
                                    <Text text="{WorkHours}" />
                                    <ObjectStatus 
                                        text="{Status}" 
                                        state="{= ${Status} === 'On Time' ? 'Success' : (${Status} === 'Late' ? 'Warning' : 'Error') }"
                                        inverted="true" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>