<mvc:View
    controllerName="com.hr.portal.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">
    <Shell id="shell">
        <tnt:ToolPage id="toolPage">
            <tnt:header>
                <tnt:ToolHeader id="_IDGenToolHeader1">
                    <Button id="_IDGenButton" icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress" />
                    <Title id="_IDGenTitle" text="HR Portal" level="H1" />
                    <ToolbarSpacer id="_IDGenToolbarSpacer" />
                    
                    <Button 
                        id="notificationBtn"
                        icon="sap-icon://bell" 
                        type="Transparent" 
                        press=".onNotificationPress"
                        class="notificationBell">
                        <customData>
                            <core:CustomData key="badge" value="3" writeToDom="true" />
                        </customData>
                    </Button>

                    <Avatar 
                        src="https://randomuser.me/api/portraits/men/32.jpg" 
                        displaySize="XS" 
                        class="sapUiSmallMarginBeginEnd" />
                </tnt:ToolHeader>
            </tnt:header>
            <tnt:sideContent>
                <tnt:SideNavigation id="_IDGenSideNavigation">
                    <tnt:NavigationList id="_IDGenNavigationList" itemSelect="onItemSelect">
                        <tnt:NavigationListItem text="Dashboard" icon="sap-icon://grid" key="RouteDashboard" />
                        <tnt:NavigationListItem text="Employees" icon="sap-icon://group" key="RouteEmployees" />
                        <tnt:NavigationListItem text="Attendance" icon="sap-icon://time-entry-request" key="RouteAttendance" />
                        <tnt:NavigationListItem text="Leave Requests" icon="sap-icon://person-placeholder" key="RouteLeaves" /> 
                        <tnt:NavigationListItem text="Documents" icon="sap-icon://document" key="RouteDocuments" />
                    </tnt:NavigationList>
                </tnt:SideNavigation>
            </tnt:sideContent>
            <tnt:mainContents>
                <App id="appId" />
            </tnt:mainContents>
        </tnt:ToolPage>
    </Shell>
</mvc:View>