<mvc:View
    controllerName="com.hr.portal.controller.EmpAttendance"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page showHeader="false" backgroundDesign="Transparent">
        <content>
            <VBox class="sapUiMediumMargin">
                <!-- Header with Request Button -->
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                    <VBox>
                        <Title text="My Attendance" level="H1" titleStyle="H3" />
                        <Text text="View your personal work hours and leave status" class="subText" />
                    </VBox>
                    <Button text="Request Leave" icon="sap-icon://post" type="Emphasized" press="onOpenLeaveDialog" />
                </HBox>

                <!-- KPI Section -->
                <HBox gap="1.5rem" class="sapUiMediumMarginBottom" justifyContent="Start">
                    <VBox width="230px" class="whiteSectionCard sapUiContentPadding">
                        <Text text="Present" class="subTextSmall" />
                        <Title text="{HRModel>/Stats/Present}" titleStyle="H1" class="statusPresentColor" />
                    </VBox>
                    <VBox width="230px" class="whiteSectionCard sapUiContentPadding">
                        <Text text="Absent" class="subTextSmall" />
                        <Title text="{HRModel>/Stats/Absent}" titleStyle="H1" class="statusAbsentColor" />
                    </VBox>
                    <VBox width="230px" class="whiteSectionCard sapUiContentPadding">
                        <Text text="Late" class="subTextSmall" />
                        <Title text="{HRModel>/Stats/Late}" titleStyle="H1" class="statusLateColor" />
                    </VBox>
                    <VBox width="230px" class="whiteSectionCard sapUiContentPadding">
                        <Text text="Half Day" class="subTextSmall" />
                        <Title text="{HRModel>/Stats/HalfDay}" titleStyle="H1" class="statusHalfDayColor" />
                    </VBox>
                </HBox>

                <!-- History Table -->
                <VBox class="whiteSectionCard sapUiContentPadding">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                        <Title text="Attendance History" titleStyle="H4" />
                        <DatePicker value="{HRModel>/CurrentDate}" width="200px" displayFormat="dd-MM-yyyy" />
                    </HBox>

                    <Table items="{HRModel>/PersonalRecords}" sticky="ColumnHeaders">
                        <columns>
                            <Column><Text text="Date" /></Column>
                            <Column hAlign="Center"><Text text="Status" /></Column>
                            <Column hAlign="Center"><Text text="Check In" /></Column>
                            <Column hAlign="Center"><Text text="Check Out" /></Column>
                            <Column><Text text="Total Hours" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{HRModel>Date}" />
                                    <ObjectStatus text="{HRModel>Status}" 
                                        state="{= ${HRModel>Status} === 'Present' ? 'Success' : (${HRModel>Status} === 'Leave Pending' ? 'Warning' : 'Error') }" />
                                    <Text text="{HRModel>CheckIn}" />
                                    <Text text="{HRModel>CheckOut}" />
                                    <Text text="{HRModel>TotalHours}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>